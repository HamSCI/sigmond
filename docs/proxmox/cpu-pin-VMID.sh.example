#!/bin/bash
# /var/lib/vz/snippets/cpu-pin-VMID.sh
# Per-vCPU pinning + per-pCPU frequency pin for VM <VMID> (sigmond).
#
# ---- How to adapt for YOUR station ----
#
# VMID                Set to your sigmond VM's id (matches `qm list`).
#
# RADIOD_CPUS         Host pCPUs that back the guest's radiod instance(s).
#                     One HT pair (2 logical CPUs) per radiod instance.
#                     Examples:
#                       1 radiod  → RADIOD_CPUS=(0 1)
#                       2 radiods → RADIOD_CPUS=(0 1 2 3)
#                       3 radiods → RADIOD_CPUS=(0 1 2 3 4 5)
#                     The vCPU pinning below is 1:1, so guest vCPUs 0,1
#                     run on host pCPUs 0,1; etc.  Sigmond's affinity logic
#                     then pins radiod inside the guest to vCPU 0,1
#                     (or vCPU 0..3 for two radiods, etc.).
#
# WORKER_CPUS         Host pCPUs that back the guest's worker pool —
#                     everything assigned to this VM minus RADIOD_CPUS.
#                     Pinned at the same freq as radiod CPUs.  Capping
#                     workers lower (e.g. 1.4 GHz) was an earlier design
#                     to limit memory-bandwidth contention; on 1-radiod
#                     deployments the worker pool needs full clock so it
#                     finishes WSPR-minute-boundary work in time.
#
# Frequencies are kHz.  Pin at the hardware max for radiod-class workloads
# (see /sys/devices/system/cpu/cpufreq/policy0/cpuinfo_{min,max}_freq).
#
# ---- Why we pin min == max instead of just setting a max cap ----
#
# The VM-assigned pCPUs run with nohz_full set (host grub: nohz_full=0-9),
# which suppresses the periodic scheduler tick on those CPUs when only one
# task is running.  amd-pstate-epp (the default cpufreq driver on Proxmox
# 8/9) uses tick-driven load samples to decide when to raise frequency.
# Without ticks it never sees load — and parks the pCPU at scaling_min_freq
# forever, even at 100% sustained CPU and even with governor=performance,
# EPP=performance.  Observed live on a 5560U: radiod FFT at 99% sustained
# CPU while the pCPU was running at 1101 MHz (the floor).
#
# Pinning min == max bypasses load detection entirely: the driver has only
# one frequency to choose, so it always picks it.  See Part 12c of
# wsprdaemon-proxmox-cpu-clock-tuning.md.

VMID=101
RADIOD_CPUS=(0 1)
RADIOD_FREQ_KHZ=4063000      # HW max (use cpuinfo_max_freq for your CPU)
WORKER_CPUS=(2 3 4 5 6 7 8 9)
WORKER_FREQ_KHZ=4063000      # HW max — workers need full clock to keep up

# ---- end of operator-tunable section ----

EVT_VMID=$1
PHASE=$2

# Pin a single pCPU to a single frequency.  Writes max first then min so the
# kernel never sees a transient min>max (which would fail the write).
pin_freq() {
    local cpu=$1 khz=$2 role=$3
    local sysmax=/sys/devices/system/cpu/cpufreq/policy${cpu}/scaling_max_freq
    local sysmin=/sys/devices/system/cpu/cpufreq/policy${cpu}/scaling_min_freq
    if echo "$khz" > "$sysmax" 2>/dev/null \
       && echo "$khz" > "$sysmin" 2>/dev/null; then
        echo "cpu-cap: pCPU ${cpu} pinned at $((khz/1000)) MHz (${role})"
    else
        echo "cpu-cap: pCPU ${cpu} FAILED to pin at $((khz/1000)) MHz (${role})"
    fi
}

if [ "$PHASE" = "post-start" ] && [ "$EVT_VMID" = "$VMID" ]; then
    # Per-pCPU frequency pin — apply first, independent of QEMU readiness.
    {
        for c in "${RADIOD_CPUS[@]}"; do
            pin_freq "$c" "$RADIOD_FREQ_KHZ" radiod
        done
        for c in "${WORKER_CPUS[@]}"; do
            pin_freq "$c" "$WORKER_FREQ_KHZ" worker
        done
    } | logger -t cpu-pin-${VMID}

    # vCPU pinning — wait for QEMU to bring up vCPU threads, then 1:1 pin.
    sleep 2
    QEMU_PID=$(cat /var/run/qemu-server/${VMID}.pid 2>/dev/null)
    if [ -z "$QEMU_PID" ]; then
        echo "cpu-pin: could not find QEMU pid for VM $VMID" | logger -t cpu-pin-${VMID}
        exit 0
    fi
    for tid in $(ps -T -p $QEMU_PID -o tid= 2>/dev/null); do
        comm=$(cat /proc/$tid/comm 2>/dev/null)
        if [[ "$comm" =~ ^CPU\ ([0-9]+)/KVM$ ]]; then
            vcpu=${BASH_REMATCH[1]}
            taskset -pc $vcpu $tid > /dev/null 2>&1
            echo "cpu-pin: VM $VMID vCPU $vcpu (tid $tid) -> host pCPU $vcpu"
        fi
    done | logger -t cpu-pin-${VMID}
fi
exit 0
